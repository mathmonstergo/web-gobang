{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "web-gobang",
  "compatibility_date": "2026-06-19",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "workers_dev": true,
  "preview_urls": true
}
